{
  "info": {
    "_postman_id": "4e986579-f9ba-4cd8-bdd0-9a40ea0c0c5f",
    "name": "Demo API Testing",
    "description": "Postman collection for demonstrating automated API testing of the FastAPI demo service.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Reset Seed State for JSON Scenario",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/admin/reset",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "admin",
            "reset"
          ]
        },
        "description": "Loads the initial seed dataset before the JSON import scenario."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "",
              "pm.test(\"Seed reset loads 3 items\", function () {",
              "    pm.expect(body.items_loaded).to.eql(3);",
              "    pm.expect(body.source_file).to.eql(\"seed_items.json\");",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Seed Items",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/items",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "items"
          ]
        },
        "description": "Checks the initial API state after reset."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "",
              "pm.test(\"Initial catalog contains 3 items\", function () {",
              "    pm.expect(body.count).to.eql(3);",
              "    pm.expect(body.items.length).to.eql(3);",
              "});",
              "",
              "pm.test(\"Seed data includes Keyboard\", function () {",
              "    pm.expect(body.items[0].name).to.eql(\"Keyboard\");",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Import Items from JSON",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": "data/import_items.json",
              "contentType": "application/json"
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/items/import/json?replace_existing=false",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "items",
            "import",
            "json"
          ],
          "query": [
            {
              "key": "replace_existing",
              "value": "false"
            }
          ]
        },
        "description": "Imports the JSON test data file."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "",
              "pm.test(\"JSON import loads 2 new items\", function () {",
              "    pm.expect(body.source_format).to.eql(\"json\");",
              "    pm.expect(body.items_loaded).to.eql(2);",
              "    pm.expect(body.current_total).to.eql(5);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Compare with Expected JSON Result",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/admin/compare/expected_after_json_import.json",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "admin",
            "compare",
            "expected_after_json_import.json"
          ]
        },
        "description": "Compares the current API state with the expected JSON reference file."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "",
              "pm.test(\"JSON scenario matches the reference file\", function () {",
              "    pm.expect(body.matches).to.eql(true);",
              "    pm.expect(body.actual_count).to.eql(5);",
              "    pm.expect(body.expected_count).to.eql(5);",
              "    pm.expect(body.differences.length).to.eql(0);",
              "});"
            ]
          }
        }
      ]
    },
