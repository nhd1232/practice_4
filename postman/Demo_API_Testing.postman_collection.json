    {
      "name": "Get Missing Item Returns 404",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/items/999",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "items",
            "999"
          ]
        },
        "description": "Checks that requesting a non-existent item returns 404."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 404\", function () {",
              "    pm.response.to.have.status(404);",
              "});",
              "",
              "const body = pm.response.json();",
              "",
              "pm.test(\"Error mentions the missing item id\", function () {",
              "    pm.expect(body.detail).to.include(\"id=999\");",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Create Item with Negative Price Returns 422",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Broken Item\",\n  \"category\": \"invalid\",\n  \"price\": -10,\n  \"quantity\": 1\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/items",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "items"
          ]
        },
        "description": "Checks validation for an invalid negative price."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 422\", function () {",
              "    pm.response.to.have.status(422);",
              "});",
              "",
              "const body = pm.response.json();",
              "",
              "pm.test(\"Validation error points to the price field\", function () {",
              "    pm.expect(body.detail.length).to.be.above(0);",
              "    pm.expect(body.detail[0].loc).to.include(\"price\");",
              "});"
            ]
          }
        }
      ]
    },
